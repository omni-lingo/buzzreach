# BuzzReach — Environment Variables
# Copy to .env and fill in real values. Never commit .env itself.

# --- Database ---
DATABASE_URL=sqlite:///data/buzzreach.db
DB_SCHEMA=buzzreach

# --- AI / Anthropic ---
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# --- Search Provider ---
SEARCH_API_KEY=REPLACE_ME
SEARCH_PROVIDER=google

# --- Auth / JWT ---
JWT_SECRET_KEY=REPLACE_WITH_A_RANDOM_SECRET
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# --- Stripe / Billing ---
STRIPE_API_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# --- Email / SMTP ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@buzzreach.app

# --- Slack ---
SLACK_WEBHOOK_URL=

# --- Config ---
CONFIG_DIR=config

# --- Server ---
HOST=0.0.0.0
PORT=8000
DEBUG=false
LOG_LEVEL=INFO
